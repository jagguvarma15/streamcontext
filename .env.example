# streamcontext configuration — copy to .env and customize.

# --- Kafka ---
SC_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SC_KAFKA_TOPICS=orders
SC_KAFKA_GROUP_ID=streamcontext-gateway
SC_KAFKA_AUTO_OFFSET_RESET=earliest

# --- Schema Registry ---
SC_SCHEMA_REGISTRY_URL=http://localhost:8081

# --- Embedder ---
# Provider: "local" (sentence-transformers) or "openai"
SC_EMBEDDER_PROVIDER=local
SC_EMBEDDER_MODEL=all-MiniLM-L6-v2
# Only used if SC_EMBEDDER_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# SC_EMBEDDER_MODEL=text-embedding-3-small

# --- Vector Sink ---
SC_SINK_PROVIDER=qdrant
SC_QDRANT_URL=http://localhost:6333
SC_QDRANT_COLLECTION=streamcontext
# Vector dim must match the embedder model. all-MiniLM-L6-v2 = 384.
SC_QDRANT_VECTOR_DIM=384

# --- Pipeline ---
SC_BATCH_SIZE=32
SC_BATCH_FLUSH_INTERVAL_SEC=1.0

# --- Payload redaction (defense in depth) ---
# Comma-separated field names to drop from the message value before it is
# written to the vector store. Applied recursively to nested dicts and lists.
# Example: SC_PAYLOAD_REDACT_FIELDS=email,phone,card_number,ssn
SC_PAYLOAD_REDACT_FIELDS=
# Headers commonly carry auth tokens or trace context. Off by default.
SC_PAYLOAD_INCLUDE_HEADERS=false
# Comma-separated value-level field names to keyword-index in the vector store.
# Required for fast filter+vector queries from the MCP search_events tool.
# Example: SC_PAYLOAD_INDEX_FIELDS=status,region,channel,currency
SC_PAYLOAD_INDEX_FIELDS=

# --- MCP server (v0.2) ---
# Comma-separated topic names the MCP server is allowed to search. If empty,
# the server logs a warning and applies no restriction. Set this to the subset
# of topics you intentionally want exposed to agents.
# Example: SC_MCP_TOPIC_ALLOWLIST=orders,clicks
SC_MCP_TOPIC_ALLOWLIST=
# Hard caps applied to every MCP tool invocation regardless of input.
SC_MCP_MAX_RESULTS=100
SC_MCP_MAX_TIME_RANGE_MINUTES=10080
SC_MCP_TOOL_TIMEOUT_SEC=5.0
# Per-tool invocations per minute. 0 disables rate limiting.
SC_MCP_RATE_LIMIT_PER_MINUTE=120
# LRU size for the embedder query cache. 0 disables.
SC_MCP_EMBED_CACHE_SIZE=256
# Approximate per-record JSON byte cap on `value` in search results.
SC_MCP_MAX_VALUE_BYTES=8192

# --- Catalog (v0.3) ---
# SQLite file backing the semantic catalog. Place on a Docker volume to make
# it survive restarts. Both the refresher and the MCP server read/write it.
SC_CATALOG_DB_PATH=/var/lib/streamcontext/catalog.sqlite
# Comma-separated list of topics the catalog covers. Defaults to SC_KAFKA_TOPICS.
SC_CATALOG_TOPICS=
# Refresh cadences (seconds). Defaults are fine for development.
SC_CATALOG_SCHEMA_REFRESH_SEC=300
SC_CATALOG_SAMPLE_REFRESH_SEC=900
SC_CATALOG_STATS_REFRESH_SEC=60
SC_CATALOG_INFERENCE_REFRESH_SEC=3600
# Sample window per topic.
SC_CATALOG_SAMPLE_COUNT=10
SC_CATALOG_SAMPLE_TIMEOUT_SEC=5.0
# Set to false to skip persisting samples; only metadata is kept.
SC_CATALOG_RETAIN_SAMPLES=true
# Set to false to skip the Kafka-side sampler entirely (e.g. when running the
# refresher in an environment without a broker available).
SC_CATALOG_ENABLE_SAMPLING=true
# LLM provider for inference (added in v0.3). 'disabled' keeps the catalog
# strictly deterministic. Other options: 'anthropic', 'openai', 'local'.
SC_CATALOG_LLM_PROVIDER=disabled
SC_CATALOG_LLM_MODEL=claude-haiku-4-5-20251001
SC_CATALOG_LLM_DAILY_CEILING_USD=1.0
SC_CATALOG_LLM_MAX_INPUT_TOKENS=5000
# Relationship detection thresholds.
SC_CATALOG_RELATIONSHIP_MIN_OVERLAP=0.2
SC_CATALOG_RELATIONSHIP_LLM_THRESHOLD=0.6
# Regex patterns and field names applied to samples before persistence and
# before any LLM submission. Comma-separated.
SC_CATALOG_PII_PATTERNS=
SC_CATALOG_PII_FIELDS=

# --- Observability ---
SC_LOG_LEVEL=INFO
SC_LOG_JSON=true

# --- Compose port binding ---
# Host interface that compose binds Kafka/SR/Qdrant ports to. Stays on loopback by
# default since none of these services run with auth. Set to 0.0.0.0 only if you
# knowingly want them reachable from other hosts.
# SC_HOST_BIND=127.0.0.1
